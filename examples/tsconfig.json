{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "composite": false,
    "jsx": "react-jsx",
    "lib": [
      "ES2023",
      "ESNext.Disposable",
      "DOM"
    ],
    "noEmit": true,
    "types": [
      "node",
      "bun"
    ]
  },
  "include": [
    "*.mjs",
    "*.ts",
    "*.tsx"
  ]
}
