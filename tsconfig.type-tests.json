{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // Disable composite/incremental inherited from tsconfig.base.json:
    // tsconfig.type-tests.json is invoked standalone (not via project references)
    // and does not emit declarations, so composite mode is inappropriate.
    "composite": false,
    "incremental": false
  },
  "include": [
    "test/types/**/*.ts"
  ],
  // references omitted intentionally: this config is invoked standalone via
  // `tsc --project tsconfig.type-tests.json`, not via `tsc -b`. Under a
  // standalone invocation the references array is silently ignored; type
  // discovery is driven by the import statements in test/types/**/*.ts.
  // To use project references here, switch to `tsc -b` and re-enable composite.
}
