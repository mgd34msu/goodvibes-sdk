{
  "name": "goodvibes-sdk",
  "private": true,
  "version": "0.18.2",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "description": "Cross-runtime GoodVibes SDK workspace for operator, peer, transport, contracts, and daemon integration surfaces.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mgd34msu/goodvibes-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mgd34msu/goodvibes-sdk/issues"
  },
  "homepage": "https://github.com/mgd34msu/goodvibes-sdk",
  "keywords": [
    "goodvibes",
    "sdk",
    "operator",
    "control-plane",
    "telemetry"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync": "bun run sync:contracts && bun run sync:transport && bun run sync:errors && bun run sync:daemon",
    "sync:contracts": "node scripts/sync-contract-artifacts.mjs",
    "sync:transport": "node scripts/sync-transport-seams.mjs",
    "sync:errors": "node scripts/sync-error-seams.mjs",
    "sync:daemon": "node scripts/sync-daemon-seams.mjs",
    "docs:generate": "node scripts/generate-api-docs.mjs",
    "docs:check": "node scripts/generate-api-docs.mjs --check && node scripts/docs-completeness-check.mjs",
    "build": "bun x tsc -b",
    "types:check": "bun x tsc --project tsconfig.type-tests.json",
    "test": "bun test test",
    "check:browser": "node scripts/browser-compat-check.mjs",
    "check:metadata": "node scripts/package-metadata-check.mjs",
    "pack:check": "node scripts/pack-check.mjs",
    "validate": "node scripts/validate.mjs",
    "release:dry-run": "node scripts/publish-packages.mjs --dry-run",
    "release:publish": "node scripts/publish-packages.mjs"
  },
  "dependencies": {
    "@goodvibes/contracts": "workspace:*",
    "@goodvibes/daemon-sdk": "workspace:*",
    "@goodvibes/operator-sdk": "workspace:*",
    "@goodvibes/peer-sdk": "workspace:*",
    "@goodvibes/sdk": "workspace:*",
    "@goodvibes/transport-core": "workspace:*",
    "@goodvibes/transport-direct": "workspace:*",
    "@goodvibes/transport-http": "workspace:*",
    "@goodvibes/transport-realtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3"
  }
}
