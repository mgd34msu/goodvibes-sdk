{
  "name": "goodvibes-sdk",
  "private": true,
  "version": "0.18.6",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "description": "Cross-runtime GoodVibes SDK workspace for operator, peer, transport, contracts, and daemon integration surfaces.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgd34msu/goodvibes-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mgd34msu/goodvibes-sdk/issues"
  },
  "homepage": "https://github.com/mgd34msu/goodvibes-sdk",
  "keywords": [
    "goodvibes",
    "sdk",
    "operator",
    "control-plane",
    "telemetry"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync": "bun run sync:contracts && bun run sync:transport && bun run sync:errors && bun run sync:daemon",
    "sync:contracts": "node scripts/sync-contract-artifacts.mjs",
    "sync:transport": "node scripts/sync-transport-seams.mjs",
    "sync:errors": "node scripts/sync-error-seams.mjs",
    "sync:daemon": "node scripts/sync-daemon-seams.mjs",
    "docs:generate": "node scripts/generate-api-docs.mjs",
    "docs:check": "node scripts/generate-api-docs.mjs --check && node scripts/docs-completeness-check.mjs",
    "prepare:sdk": "node scripts/prepare-sdk-package.mjs",
    "build": "bun x tsc -b && bun run prepare:sdk",
    "types:check": "bun x tsc --project tsconfig.type-tests.json",
    "test": "bun test test",
    "validate:source": "node scripts/validate-source.mjs",
    "check:browser": "node scripts/browser-compat-check.mjs",
    "check:metadata": "node scripts/package-metadata-check.mjs",
    "pack:check": "node scripts/pack-check.mjs",
    "install:smoke": "node scripts/install-smoke-check.mjs",
    "release:verify": "bun run validate && bun run release:dry-run && bun run install:smoke",
    "release:verify:published": "node scripts/verify-published-packages.mjs && node scripts/install-smoke-check.mjs --registry",
    "validate": "node scripts/validate.mjs",
    "release:dry-run": "node scripts/publish-packages.mjs --dry-run",
    "release:publish": "node scripts/publish-packages.mjs"
  },
  "dependencies": {
    "@pellux/goodvibes-contracts": "workspace:*",
    "@pellux/goodvibes-daemon-sdk": "workspace:*",
    "@pellux/goodvibes-operator-sdk": "workspace:*",
    "@pellux/goodvibes-peer-sdk": "workspace:*",
    "@pellux/goodvibes-sdk": "workspace:*",
    "@pellux/goodvibes-transport-core": "workspace:*",
    "@pellux/goodvibes-transport-direct": "workspace:*",
    "@pellux/goodvibes-transport-http": "workspace:*",
    "@pellux/goodvibes-transport-realtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3"
  }
}
