{
  "name": "goodvibes-sdk",
  "private": true,
  "version": "0.30.3",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": "1.3.10",
    "node": ">=22.0.0"
  },
  "description": "TypeScript SDK for building GoodVibes operator, peer, web, mobile, and daemon-connected apps with typed contracts, auth, realtime events, and transport layers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgd34msu/goodvibes-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mgd34msu/goodvibes-sdk/issues"
  },
  "homepage": "https://github.com/mgd34msu/goodvibes-sdk",
  "keywords": [
    "goodvibes",
    "sdk",
    "operator",
    "control-plane",
    "telemetry"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "changelog:check": "bun scripts/check-changelog.ts",
    "contracts:check": "bun scripts/check-contract-artifacts.ts",
    "sync:version": "bun scripts/sync-version-fallback.ts",
    "docs:generate": "bun scripts/generate-api-docs.ts",
    "docs:check": "bun scripts/generate-api-docs.ts --check && bun scripts/docs-completeness-check.ts",
    "refresh:contracts": "bun scripts/refresh-contract-artifacts.ts",
    "refresh:contracts:check": "bun scripts/refresh-contract-artifacts.ts --check",
    "refresh:docs": "bun run refresh:contracts && bun run docs:generate",
    "prepare:sdk": "bun scripts/prepare-sdk-package.ts",
    "build": "bun scripts/build.ts",
    "types:check": "node node_modules/typescript/bin/tsc --project tsconfig.type-tests.json",
    "pretest": "bun run build",
    "test": "bun scripts/test.ts",
    "test:rn": "bun run build && bun scripts/test.ts test/rn-bundle-node-imports.test.ts",
    "test:workers": "bun run build && bun scripts/test.ts test/workers/workers.test.ts",
    "check:browser": "bun scripts/browser-compat-check.ts",
    "check:metadata": "bun scripts/package-metadata-check.ts",
    "pack:check": "bun scripts/pack-check.ts",
    "install:smoke": "bun scripts/install-smoke-check.ts",
    "error:check": "bun scripts/error-contract-check.ts",
    "test-skip:check": "bun scripts/no-skipped-tests.ts",
    "release:verify": "bun run validate && bun run release:dry-run && bun run install:smoke",
    "release:verify:published": "bun scripts/verify-published-packages.ts && bun scripts/install-smoke-check.ts --registry",
    "validate": "bun scripts/validate.ts",
    "validate:strict": "bun run validate && bun run types:check && bun run contracts:check",
    "release:dry-run": "bun scripts/publish-packages.ts --dry-run",
    "release:publish": "bun scripts/publish-packages.ts",
    "version:check": "bun scripts/version-consistency-check.ts",
    "types:resolution-check": "bunx attw --pack packages/sdk --ignore-rules no-resolution cjs-resolves-to-esm",
    "publint:check": "publint packages/sdk",
    "sbom:generate": "bun scripts/sbom-generate.ts",
    "release:tag": "bun scripts/create-release-tag.ts",
    "release:publish:ci": "bun scripts/publish-packages.ts --provenance",
    "release:verify:verdaccio": "bun scripts/verdaccio-dry-run.ts",
    "bundle:check": "bun scripts/bundle-budget.ts",
    "todo:check": "bun scripts/no-todo-markers.ts",
    "security:audit": "bun audit --audit-level high",
    "flake:check": "bun scripts/flake-detect.ts",
    "api:extract": "bunx api-extractor run --local",
    "api:check": "bunx api-extractor run",
    "test:workers:wrangler": "bun run build && bun scripts/test.ts test/workers-wrangler/wrangler.test.ts",
    "any:check": "bun scripts/no-any-types.ts",
    "platform-console:check": "bun scripts/no-platform-console.ts",
    "dist:check": "bun scripts/check-dist-freshness.ts"
  },
  "dependencies": {
    "@pellux/goodvibes-contracts": "workspace:*",
    "@pellux/goodvibes-daemon-sdk": "workspace:*",
    "@pellux/goodvibes-errors": "workspace:*",
    "@pellux/goodvibes-operator-sdk": "workspace:*",
    "@pellux/goodvibes-peer-sdk": "workspace:*",
    "@pellux/goodvibes-sdk": "workspace:*",
    "@pellux/goodvibes-transport-core": "workspace:*",
    "@pellux/goodvibes-transport-http": "workspace:*",
    "@pellux/goodvibes-transport-realtime": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@cloudflare/workers-types": "4.20260503.1",
    "@cyclonedx/cyclonedx-npm": "4.2.1",
    "@microsoft/api-extractor": "^7.58.4",
    "@types/bun": "^1.3.10",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.16.5",
    "fast-check": "4.7.0",
    "miniflare": "^4.20260415.0",
    "msw": "^2.7.0",
    "publint": "0.3.18",
    "typescript": "6.0.3",
    "verdaccio": "^6.5.2",
    "wrangler": "4.87.0",
    "@ast-grep/napi": "^0.42.0"
  },
  "overridesRationale": {
    "ajv": "Pinned to keep JSON Schema validation on the audited 8.x line used by release tooling dependencies.",
    "bash-language-server": "Vendored to keep shell language support while preserving a clean high-severity audit surface for the Verdaccio dry-run dependency graph.",
    "fast-xml-parser": "Pinned to the audited 5.x parser release used by transitive Google/Cloud tooling.",
    "google-auth-library": "Pinned to an audited release for Cloudflare/Wrangler transitive auth tooling.",
    "lodash": "Pinned away from vulnerable transitive ranges in release-tool dependencies that have not moved off lodash.",
    "minimatch": "Pinned to a patched glob matcher across build and release transitive dependencies.",
    "uuid": "Vendored CommonJS uuid v4 package for Verdaccio @cypress/request, which still requires a CommonJS uuid entry."
  },
  "overrides": {
    "ajv": "8.18.0",
    "fast-xml-parser": "5.7.1",
    "google-auth-library": "10.6.2",
    "bash-language-server": "file:vendor/bash-language-server",
    "lodash": "4.17.21",
    "minimatch": "^10.2.5",
    "uuid": "file:vendor/uuid-cjs"
  }
}
