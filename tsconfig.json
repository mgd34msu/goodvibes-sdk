{
  "compilerOptions": {
    // composite: true is nominally required for project references but has no
    // build effect here because files: [] means no source is compiled at this
    // root. It satisfies the TypeScript composite constraint checker so that
    // child packages can reference this root without an error.
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": ".tmp/tsbuildinfo/tsconfig.tsbuildinfo",
    "types": []
  },
  // tsconfig.type-tests.json is intentionally excluded from this composite root.
  // It is not a project reference because it uses `paths` remapping and does not
  // emit declarations — including it here would break the composite build chain.
  // It is invoked independently via `bun run types:check` (api-extractor + attw).
  "files": [],
  "references": [
    {
      "path": "./packages/contracts"
    },
    {
      "path": "./packages/errors"
    },
    {
      "path": "./packages/daemon-sdk"
    },
    {
      "path": "./packages/transport-core"
    },
    {
      "path": "./packages/transport-http"
    },
    {
      "path": "./packages/transport-realtime"
    },
    {
      "path": "./packages/operator-sdk"
    },
    {
      "path": "./packages/peer-sdk"
    },
    {
      "path": "./packages/sdk"
    }
  ]
}
