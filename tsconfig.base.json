{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2024",
      // ESNext.Disposable adds Symbol.dispose / Symbol.asyncDispose type definitions.
      // Although target is ES2024, the Disposables proposal shipped in ES2025 —
      // this lib entry provides the type stubs without changing emit target.
      // SOURCE: https://github.com/tc39/proposal-explicit-resource-management
      // Tested with TypeScript 6.0.3 (typescript devDependency pin).
      // Re-evaluate when bumping `target` to `ES2025` or later — `ESNext.Disposable`
      // will fold into the standard lib and this explicit entry can be removed.
      "ESNext.Disposable"
    ],
    "strict": true,
    // Stricter-adjacent flags not covered by `strict`. These surface real bugs
    // (noUncheckedIndexedAccess) and enforce explicit override intent.
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}
