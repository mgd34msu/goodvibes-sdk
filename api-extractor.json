{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",

  "projectFolder": ".",

  "mainEntryPointFilePath": "<projectFolder>/packages/sdk/dist/index.d.ts",

  "bundledPackages": [
    "@pellux/goodvibes-contracts",
    "@pellux/goodvibes-daemon-sdk",
    "@pellux/goodvibes-errors",
    "@pellux/goodvibes-operator-sdk",
    "@pellux/goodvibes-peer-sdk",
    "@pellux/goodvibes-transport-core",
    "@pellux/goodvibes-transport-http",
    "@pellux/goodvibes-transport-realtime"
  ],

  "compiler": {
    "tsconfigFilePath": "<projectFolder>/packages/sdk/tsconfig.api-extractor.json",
    "overrideTsconfig": {
      "compilerOptions": {
        "paths": {}
      }
    }
  },

  "apiReport": {
    "enabled": true,
    "reportFileName": "goodvibes-sdk.api.md",
    "reportFolder": "<projectFolder>/etc/",
    "reportTempFolder": "<projectFolder>/temp/"
  },

  "docModel": {
    "enabled": false
  },

  "dtsRollup": {
    "enabled": false
  },

  "tsdocMetadata": {
    "enabled": false
  },

  "messages": {
    "compilerMessageReporting": {
      "default": {
        "logLevel": "warning"
      },
      // TS1259: Module can only be default-imported using 'esModuleInterop'.
      // Triggered by: type-only star-re-exports in packages/sdk/src/transport-core.ts,
      // transport-http.ts, and transport-realtime.ts that re-export from bundledPackages
      // without a default import reference (e.g. `export * from '@pellux/goodvibes-transport-core'`).
      // Re-evaluate when api-extractor upgrades to a TS6+ bundled compiler.
      "TS1259": { "logLevel": "none" },
      // TS2305: Module has no exported member.
      // Triggered by: @pellux/goodvibes-transport-core `observer` export — api-extractor
      // resolves the dist snapshot which may pre-date the current build; the `observer`
      // export exists in packages/transport-core/dist/observer.d.ts at runtime.
      // Re-evaluate when the transport-core dist is rebuilt and a clean api-extractor pass succeeds.
      "TS2305": { "logLevel": "none" },
      // TS2307: Cannot find module or its corresponding type declarations.
      // Triggered by: optional peer deps declared as ambient modules but not installed:
      //   - expo-secure-store, react-native-keychain (packages/sdk/src/platform/types/peer-deps.d.ts)
      //   - pdfjs-dist/legacy/build/pdf.mjs (packages/sdk/src/platform/types/pdfjs-dist.d.ts)
      //   - sql.js (packages/sdk/src/platform/types/sql-js.d.ts)
      //   - WASM path modules (packages/sdk/src/platform/types/wasm-files.d.ts)
      // Re-evaluate if any of these deps is promoted to a direct SDK dependency or bundledPackage.
      "TS2307": { "logLevel": "none" },
      // TS2344: Type does not satisfy the constraint.
      // Triggered by: conditional type narrowing in api-extractor's reduced checker against
      // transport types — specifically DirectClientTransport and EventEnvelope<T> generic
      // parameters in packages/transport-core/dist/.
      // Re-evaluate when api-extractor upgrades to a TS6+ bundled compiler.
      "TS2344": { "logLevel": "none" },
      // TS2694: Namespace has no exported member.
      // Triggered by: ambient `declare module` blocks in
      //   - packages/sdk/src/platform/types/peer-deps.d.ts (expo-secure-store, react-native-keychain)
      //   - packages/sdk/src/platform/types/sql-js.d.ts (sql.js Database/SqlJsStatic)
      //   - packages/sdk/src/platform/types/wasm-files.d.ts (WASM path modules)
      // api-extractor cannot resolve namespace members from ambient module augmentations.
      // Re-evaluate when these type files migrate to direct package exports or bundledPackages.
      "TS2694": { "logLevel": "none" },
      // TS2707: Generic type requires between N and M type arguments.
      // Triggered by: ReadableStream<Uint8Array> uses in
      // packages/sdk/src/platform/runtime/integration/helpers.ts:617 and
      // packages/sdk/src/platform/runtime/telemetry/api-stream.ts:44 —
      // api-extractor's bundled lib.dom.d.ts omits default type parameter values
      // present in the full TypeScript lib.
      // Re-evaluate when api-extractor ships a TS6-compatible bundled compiler with
      // a complete lib.dom.d.ts.
      "TS2707": { "logLevel": "none" },
      // TS2702: Type only refers to a type, but is being used as a namespace here.
      // Triggered by: vendored qrcodegen.d.ts (QrCode, QrSegment) and bash-language-server
      // tree-sitter parser type ('Parser' namespace). Upstream types we cannot patch
      // without forking; runtime behaviour is unaffected.
      "TS2702": { "logLevel": "none" },
      // TS2709: Cannot use namespace as a type.
      // Triggered by: vendor/bash-language-server tree-sitter parser type imports.
      // Same root cause as TS2702 above; suppressed for the vendored upstream.
      "TS2709": { "logLevel": "none" },
      // TS18028: Private identifiers are only available when targeting ECMAScript 2015.
      // Triggered by: oauth-client.d.ts:19 — api-extractor's reduced checker does not
      // honour the project's `target: "es2022"` setting and falls back to a pre-ES2015
      // default. The runtime targets are all ES2022+.
      "TS18028": { "logLevel": "none" },
      // TS2552: Cannot find name 'X'.
      // Triggered by: bun-types overrides.d.ts:316 referencing 'ConnectionOptions' from
      // node:tls which api-extractor's reduced lib.d.ts does not expose. Confirmed by
      // grep that no first-party code references ConnectionOptions.
      "TS2552": { "logLevel": "none" },
      // TS2304: Cannot find name 'X'. (without "Did you mean...")
      // Triggered by: bun-types overrides.d.ts:360 ('TLSSocket') and
      // web-tree-sitter@0.26.8 ('EmscriptenModule'). Both upstream type packages reference
      // names api-extractor's reduced lib.d.ts does not expose; confirmed by grep that no
      // first-party code references these names.
      "TS2304": { "logLevel": "none" }
    },
    "extractorMessageReporting": {
      "default": {
        "logLevel": "warning",
        "addToApiReportFile": false
      },
      // Bundled packages keep implementation declarations out of the published
      // API report; consumers rely on the generated api.md report for the
      // authoritative surface.
      "ae-missing-release-tag": {
        "logLevel": "none"
      },
      "ae-unresolved-inheritdoc-reference": {
        "logLevel": "none"
      },
      // Public declarations whose dependency types have no report entry are
      // handled by explicit package exports and the generated API report.
      "ae-forgotten-export": {
        "logLevel": "none"
      }
    },
    "tsdocMessageReporting": {
      "default": {
        "logLevel": "none"
      }
    }
  }
}
