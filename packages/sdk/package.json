{
  "name": "@pellux/goodvibes-sdk",
  "version": "0.18.3",
  "description": "Umbrella GoodVibes SDK with operator, peer, daemon, transport, and runtime-specific integration layers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "import": "./dist/react-native.js"
    },
    "./expo": {
      "types": "./dist/expo.d.ts",
      "import": "./dist/expo.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgd34msu/goodvibes-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mgd34msu/goodvibes-sdk/issues"
  },
  "homepage": "https://github.com/mgd34msu/goodvibes-sdk",
  "keywords": [
    "goodvibes",
    "sdk",
    "browser",
    "react-native",
    "control-plane"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pellux/goodvibes-contracts": "workspace:*",
    "@pellux/goodvibes-daemon-sdk": "workspace:*",
    "@pellux/goodvibes-errors": "workspace:*",
    "@pellux/goodvibes-operator-sdk": "workspace:*",
    "@pellux/goodvibes-peer-sdk": "workspace:*",
    "@pellux/goodvibes-transport-core": "workspace:*",
    "@pellux/goodvibes-transport-direct": "workspace:*",
    "@pellux/goodvibes-transport-http": "workspace:*",
    "@pellux/goodvibes-transport-realtime": "workspace:*"
  }
}
