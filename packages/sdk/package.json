{
  "name": "@pellux/goodvibes-sdk",
  "version": "0.18.17",
  "description": "Umbrella GoodVibes SDK with operator, peer, daemon, transport, and runtime-specific integration layers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js"
    },
    "./contracts/node": {
      "types": "./dist/contracts-node.d.ts",
      "import": "./dist/contracts-node.js"
    },
    "./contracts/operator-contract.json": "./dist/_internal/contracts/artifacts/operator-contract.json",
    "./contracts/peer-contract.json": "./dist/_internal/contracts/artifacts/peer-contract.json",
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./daemon": {
      "types": "./dist/daemon.d.ts",
      "import": "./dist/daemon.js"
    },
    "./operator": {
      "types": "./dist/operator.d.ts",
      "import": "./dist/operator.js"
    },
    "./peer": {
      "types": "./dist/peer.d.ts",
      "import": "./dist/peer.js"
    },
    "./transport-core": {
      "types": "./dist/transport-core.d.ts",
      "import": "./dist/transport-core.js"
    },
    "./transport-direct": {
      "types": "./dist/transport-direct.d.ts",
      "import": "./dist/transport-direct.js"
    },
    "./transport-http": {
      "types": "./dist/transport-http.d.ts",
      "import": "./dist/transport-http.js"
    },
    "./transport-realtime": {
      "types": "./dist/transport-realtime.d.ts",
      "import": "./dist/transport-realtime.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "import": "./dist/react-native.js"
    },
    "./expo": {
      "types": "./dist/expo.d.ts",
      "import": "./dist/expo.js"
    },
    "./platform/*": {
      "types": "./dist/_internal/platform/*.d.ts",
      "import": "./dist/_internal/platform/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgd34msu/goodvibes-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mgd34msu/goodvibes-sdk/issues"
  },
  "homepage": "https://github.com/mgd34msu/goodvibes-sdk",
  "keywords": [
    "goodvibes",
    "sdk",
    "browser",
    "react-native",
    "control-plane"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@anthropic-ai/bedrock-sdk": "^0.28.1",
    "@anthropic-ai/sdk": "^0.82.0",
    "@anthropic-ai/vertex-sdk": "^0.16.0",
    "@ast-grep/napi": "^0.42.0",
    "@aws/bedrock-token-generator": "^1.1.0",
    "bash-language-server": "^5.6.0",
    "fuse.js": "^7.1.0",
    "graphql": "^16.13.2",
    "jszip": "^3.10.1",
    "node-edge-tts": "^1.2.10",
    "openai": "^6.29.0",
    "pyright": "^1.1.408",
    "simple-git": "^3.33.0",
    "sql.js": "^1.14.1",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-css": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "typescript-language-server": "^5.1.3",
    "vscode-langservers-extracted": "^4.10.0",
    "web-tree-sitter": "^0.26.7",
    "zustand": "^5.0.12"
  }
}
