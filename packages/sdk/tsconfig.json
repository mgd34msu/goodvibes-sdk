{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "lib": [
      "ES2024",
      // DOM is intentionally included for this package:
      // packages/sdk/src includes both browser/RN client code (needs DOM globals
      // like WebSocket, fetch, EventSource, URLSearchParams) and Node/Bun daemon
      // code. Splitting into separate tsconfig.node.json would require duplicating
      // references and paths across multiple configs with no compile-time benefit
      // because daemon-side files already exclude DOM-only APIs by convention.
      // Acceptable trade-off until the browser and daemon entrypoints are separated
      // into distinct sub-packages.
      "DOM"
    ],
    "types": [
      "node",
      "bun"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ],
  "references": [
    {
      "path": "../contracts"
    },
    {
      "path": "../errors"
    },
    {
      "path": "../daemon-sdk"
    },
    {
      "path": "../transport-core"
    },
    {
      "path": "../transport-http"
    },
    {
      "path": "../transport-realtime"
    },
    {
      "path": "../operator-sdk"
    },
    {
      "path": "../peer-sdk"
    }
  ]
}
