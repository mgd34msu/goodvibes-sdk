{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "types": [
      "node",
      "bun"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ],
  "references": [
    {
      "path": "../contracts"
    },
    {
      "path": "../errors"
    },
    {
      "path": "../daemon-sdk"
    },
    {
      "path": "../transport-core"
    },
    {
      "path": "../transport-http"
    },
    {
      "path": "../transport-realtime"
    },
    {
      "path": "../operator-sdk"
    },
    {
      "path": "../peer-sdk"
    }
  ]
}
