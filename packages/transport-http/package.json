    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./backoff": {
      "types": "./dist/backoff.d.ts",
      "import": "./dist/backoff.js"
    },
    "./contract-client": {
      "types": "./dist/contract-client.d.ts",
      "import": "./dist/contract-client.js"
    },
    "./http-core": {
      "types": "./dist/http-core.d.ts",
      "import": "./dist/http-core.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
