{
  "name": "@pellux/goodvibes-transport-core",
  "version": "0.33.14",
  "engines": {
    "bun": "1.3.10",
    "node": ">=22.0.0"
  },
  "description": "Shared GoodVibes client transport primitives for direct, HTTP, and realtime integrations.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client-transport": {
      "types": "./dist/client-transport.d.ts",
      "import": "./dist/client-transport.js"
    },
    "./direct": {
      "types": "./dist/direct.d.ts",
      "import": "./dist/direct.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./event-envelope": {
      "types": "./dist/event-envelope.d.ts",
      "import": "./dist/event-envelope.js"
    },
    "./event-feeds": {
      "types": "./dist/event-feeds.d.ts",
      "import": "./dist/event-feeds.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./observer": {
      "types": "./dist/observer.d.ts",
      "import": "./dist/observer.js"
    },
    "./otel": {
      "types": "./dist/otel.d.ts",
      "import": "./dist/otel.js"
    },
    "./uuid": {
      "types": "./dist/uuid.d.ts",
      "import": "./dist/uuid.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "@pellux/goodvibes-errors": "workspace:*"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgd34msu/goodvibes-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mgd34msu/goodvibes-sdk/issues"
  },
  "homepage": "https://github.com/mgd34msu/goodvibes-sdk",
  "keywords": [
    "goodvibes",
    "sdk",
    "transport",
    "events",
    "client"
  ],
  "publishConfig": {
    "access": "public"
  }
}
