{
  "name": "@pellux/goodvibes-transport-realtime",
  "version": "0.33.23",
  "engines": {
    "bun": "1.3.10",
    "node": ">=22.0.0"
  },
  "description": "Realtime event-domain connectors for GoodVibes SSE and WebSocket integrations.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./domain-events": {
      "types": "./dist/domain-events.d.ts",
      "import": "./dist/domain-events.js"
    },
    "./runtime-events": {
      "types": "./dist/runtime-events.d.ts",
      "import": "./dist/runtime-events.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgd34msu/goodvibes-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mgd34msu/goodvibes-sdk/issues"
  },
  "homepage": "https://github.com/mgd34msu/goodvibes-sdk",
  "keywords": [
    "goodvibes",
    "sdk",
    "realtime",
    "websocket",
    "events"
  ],
  "dependencies": {
    "@pellux/goodvibes-contracts": "workspace:*",
    "@pellux/goodvibes-errors": "workspace:*",
    "@pellux/goodvibes-transport-core": "workspace:*",
    "@pellux/goodvibes-transport-http": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
