{
  "name": "@pellux/goodvibes-peer-sdk",
  "version": "0.30.5",
  "engines": {
    "bun": "1.3.10",
    "node": ">=22.0.0"
  },
  "description": "HTTP client for GoodVibes distributed-runtime peer APIs and work exchange flows.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client-core": {
      "types": "./dist/client-core.d.ts",
      "import": "./dist/client-core.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgd34msu/goodvibes-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mgd34msu/goodvibes-sdk/issues"
  },
  "homepage": "https://github.com/mgd34msu/goodvibes-sdk",
  "keywords": [
    "goodvibes",
    "sdk",
    "peer",
    "distributed-runtime",
    "client"
  ],
  "_comment_deps": "peer-sdk intentionally omits a direct zod dependency: all schema validation is delegated to @pellux/goodvibes-contracts (which depends on zod). If peer-sdk source ever imports zod directly, add zod as an explicit dep to avoid relying on the transitive resolution path.",
  "dependencies": {
    "@pellux/goodvibes-contracts": "workspace:*",
    "@pellux/goodvibes-errors": "workspace:*",
    "@pellux/goodvibes-transport-http": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
