{
  "name": "@pellux/goodvibes-operator-sdk",
  "version": "0.33.5",
  "engines": {
    "bun": "1.3.10",
    "node": ">=22.0.0"
  },
  "description": "Contract-driven HTTP client for the GoodVibes operator and control-plane APIs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client-core": {
      "types": "./dist/client-core.d.ts",
      "import": "./dist/client-core.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgd34msu/goodvibes-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mgd34msu/goodvibes-sdk/issues"
  },
  "homepage": "https://github.com/mgd34msu/goodvibes-sdk",
  "keywords": [
    "goodvibes",
    "sdk",
    "operator",
    "control-plane",
    "client"
  ],
  "dependencies": {
    "@pellux/goodvibes-contracts": "workspace:*",
    "@pellux/goodvibes-errors": "workspace:*",
    "@pellux/goodvibes-transport-http": "workspace:*",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
